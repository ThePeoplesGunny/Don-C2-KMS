{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DoN C2 KMS",
  "version": "1.0.0",
  "identifier": "mil.navy.don-c2-kms",
  "build": {
    "frontendDist": "../web",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "DoN C2 KMS v1.0",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
